 #[pyclass]
@@ -10,6 +11,7 @@ pub struct ChessGame {
     worker: SearchWorker,
 }

+fn sq_to_uci(sq: u8) -> String {
+    let file = (sq % 8) as u8;
+    let rank = (sq / 8) as u8;
+    format!("{}{}", (b'a' + file) as char, (b'1' + rank) as char)
+}

+fn move_to_uci(mv: &Move) -> String {
+    let mut s = format!("{}{}", sq_to_uci(mv.start_sq), sq_to_uci(mv.end_sq));
+
+    if mv.is_promotion() {
+        let promo = match mv.promotion_piece {
+            crate::pieces::PieceType::Queen => 'q',
+            crate::pieces::PieceType::Rook => 'r',
+            crate::pieces::PieceType::Bishop => 'b',
+            crate::pieces::PieceType::Knight => 'n',
+            _ => 'q',
+        };
+        s.push(promo);
+    }
+
+    s
+}

 #[pymethods]
